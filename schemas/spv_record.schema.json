{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://athena.dev/channel-atlas/spv-record.schema.json",
  "title": "ChannelAtlas SPV record",
  "type": "object",
  "required": ["spv_id", "legal_name", "jurisdiction", "formation_date", "sponsoring_filer", "purpose_text", "source_filings"],
  "additionalProperties": false,
  "properties": {
    "spv_id": {"type": "string"},
    "legal_name": {"type": "string"},
    "jurisdiction": {"type": "string"},
    "formation_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "sponsoring_filer": {"type": "string"},
    "purpose_text": {"type": "string"},
    "source_filings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "accession_number", "cited_at"],
        "additionalProperties": false,
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "accession_number": {"type": "string"},
          "cited_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
        }
      }
    }
  }
}

