{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://athena.dev/channel-atlas/counterparty-edge.schema.json",
  "title": "ChannelAtlas counterparty edge",
  "type": "object",
  "required": ["edge_id", "from_entity", "to_entity", "relationship_type", "commitment_amount", "commitment_currency", "disclosure_date", "source_filings"],
  "additionalProperties": false,
  "properties": {
    "edge_id": {"type": "string"},
    "from_entity": {"type": "string"},
    "to_entity": {"type": "string"},
    "relationship_type": {"type": "string"},
    "commitment_amount": {"type": "number", "minimum": 0},
    "commitment_currency": {"type": "string"},
    "disclosure_date": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "source_filings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "accession_number", "cited_at"],
        "additionalProperties": false,
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "accession_number": {"type": "string"},
          "cited_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
        }
      }
    }
  }
}

